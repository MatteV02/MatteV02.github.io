---
// This page redirects the user to their preferred language automatically.
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>matteo.veroni</title>
  <script is:inline>
    // 1. Check if user explicitly chose a language previously
    let preferredLang = localStorage.getItem("primapersona_lang");
    
    // 2. If not, auto-detect from browser
    if (!preferredLang) {
      const browserLang = navigator.language || navigator.userLanguage || "en";
      preferredLang = browserLang.toLowerCase().startsWith("it") ? "it" : "en";
    }

    // 3. Redirect immediately to the correct locale path
    window.location.replace(`/${preferredLang}/`);
  </script>
</head>
<body style="background-color: #0f0f0f;">
</body>
</html>
