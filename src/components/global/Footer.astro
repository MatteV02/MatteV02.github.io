---
// Assets
import Logo from "@/components/assets/Logo.astro";
// Foundations
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import { getEntry } from "astro:content";

const currentLocale = Astro.currentLocale || "en";
const footerEntry = await getEntry("globals", `footer_${currentLocale}`);
const { links = [] } = footerEntry?.data || {};
const year = new Date().getFullYear();
---

<footer>
  <Wrapper variant="standard" class="py-2">
    <div class="grid grid-cols-2 lg:grid-cols-4 items-start">
      <div
        class="flex items-center gap-2 text-base-600 dark:text-base-300 text-xs tracking-tight"
      >
        {year}
        <Logo />
      </div>
      <div class="flex flex-wrap gap-8 text-sm items-center">
        {
          links?.map((link) => (
            <a
              href={link.href}
              class="text-base-600 tracking-tight  text-xs hover:text-base-900 dark:text-white transition-colors"
            >
              {link.text}
            </a>
          ))
        }
      </div>
    </div>
  </Wrapper>
</footer>
