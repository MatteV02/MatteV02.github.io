---
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Button from "@/components/fundations/elements/Button.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
const { data } = Astro.props;
---

<section>
  <Wrapper variant="standard" class="pb-8 pt-40 lg:pt-80">
    <div class="grid grid-cols-1 lg:grid-cols-4 items-start gap-y-8">
      <Text
        tag="h1"
        variant="displayLG"
        class="font-semibold leading-snug text-left tracking-tighter lg:col-span-2 text-base-900 dark:text-white lg:col-start-3"
      >
        {data?.text}
      </Text>
      
      {data?.action && (
        <div class="lg:col-span-2 lg:col-start-3 flex mt-4">
          <Button isLink href={data.action.link} download variant="default" size="base">
            {data.action.label}
          </Button>
        </div>
      )}
    </div>
  </Wrapper>
</section>
