---
// Assets
import { Image } from "astro:assets";
// Fundations
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";

const { data } = Astro.props;
const { label, title, items } = data || {};
---

<section class="scroll-mt-32" id="projects">
  <Wrapper variant="standard" class="py-12 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-4 items-start">
      <div class="lg:col-start-2">
        <Text tag="p" variant="textSM" class="text-base-600 dark:text-base-300" set:html={label} />
      </div>
      <Text
        tag="h2"
        variant="textXL"
        class="font-semibold leading-snug text-left tracking-tighter lg:col-span-2 text-base-900 dark:text-white"
      >
        {title}
      </Text>
    </div>

    <div class="flex flex-col gap-12 mt-8">
      {
        items?.map((project) => (
          <article class="py-12 border-t border-base-200 dark:border-base-800">
            <div class="grid grid-cols-1 gap-4 lg:grid-cols-4 items-start">
              <Text
                tag="p"
                variant="textXS"
                class="text-base-600 dark:text-base-300 uppercase"
              >
                {project.year}
              </Text>
              <Text
                tag="h3"
                variant="displaySM"
                class="text-base-900 dark:text-white leading-tight font-semibold "
              >
                {project.title}
              </Text>
              <Text
                tag="p"
                variant="textSM"
                class="text-base-600 dark:text-base-300"
              >
                {project.description}
              </Text>
              <div class="flex items-center gap-3 lg:ml-auto lg:col-start-4">
                {project.logo && <Image src={project.logo} alt="" class="w-8 h-8 object-contain shrink-0" />}
                <Text
                  tag="p"
                  variant="textXS"
                  class="text-base-600 dark:text-base-300 uppercase"
                >
                  {project.category}
                </Text>
              </div>
            </div>
            <Image
              width={1200}
              height={630}
              src={project.image}
              alt={project.imageAlt}
              loading="lazy"
              decoding="async"
              class="size-full aspect-4/2 rounded-4xl mt-12 object-cover object-center"
            />
          </article>
        ))
      }
    </div>
  </Wrapper>
</section>
